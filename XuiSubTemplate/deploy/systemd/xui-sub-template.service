[Unit]
Description=XuiSubTemplate Gunicorn Service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/xui-sub-template/XuiSubTemplate
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/opt/xui-sub-template/XuiSubTemplate/.env
ExecStart=/opt/xui-sub-template/venv/bin/gunicorn --config /opt/xui-sub-template/XuiSubTemplate/deploy/gunicorn/gunicorn.conf.py XuiSubTemplate.wsgi:application
Restart=always
RestartSec=5
TimeoutStopSec=30
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
